# ============================
# DOBA API 配置
# ============================
DOBA_APP_KEY=your_doba_app_key
DOBA_PRIVATE_KEY=your_doba_private_key_base64
DOBA_BASE_URL=https://openapi.doba.com

# ============================
# 简道云 API 配置
# ============================
JD_API_KEY=your_jiandao_api_key
JD_BASE_URL=https://api.jiandaoyun.com

# 简道云表单配置
JD_APP_ID=your_app_id
JD_FORM_PRODUCT=产品表单entry_id
JD_FORM_ORDER=订单表单entry_id

# ============================
# 服务配置
# ============================
PORT=3200
NODE_ENV=development

# ============================
# 支付方式
# ============================
# 7 = 预付余额, 0 = 信用卡
DOBA_PAYMENT_METHOD=7
